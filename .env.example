# EvidenceFlow AI — Environment Variables
# Copy this file to .env and fill in your values

# AI Provider Configuration
# Options: mock | openai | deepseek | custom
VITE_AI_PROVIDER=mock

# API Keys (only needed for non-mock providers)
# VITE_OPENAI_API_KEY=sk-...
# VITE_DEEPSEEK_API_KEY=sk-...
# VITE_CUSTOM_API_KEY=sk-...

# Custom Provider Base URL (only for 'custom' provider)
# VITE_CUSTOM_BASE_URL=https://api.example.com/v1

# Default Model (used for OpenAI-compatible providers)
# VITE_AI_MODEL=gpt-4o
