erDiagram
    Workspace ||--o{ Document : contains
    Workspace ||--o{ AnalysisProject : has
    Document ||--o{ DocumentChunk : chunks
    Document ||--o{ AIConversation : conversations
    Document ||--o{ KnowledgeCard : cards
    AIConversation ||--o{ AIMessage : messages
    AIMessage ||--o{ Citation : cites
    Citation }o--|| DocumentChunk : references
    Claim ||--o{ Evidence : supported_by
    Evidence }o--|| Citation : links_to
    Evidence }o--|| Document : from
    AnalysisProject ||--o{ ConflictItem : generates
    AnalysisProject ||--o{ ConsensusTopic : identifies
    AnalysisProject ||--o{ DecisionBrief : produces
    DecisionBrief ||--o{ BriefSection : sections
    BriefSection ||--o{ Citation : includes
    UserSettings }o--|| User : configures
    ActivityLog }o--|| User : recorded_by

    Workspace {
        string id PK
        string name
        string description
        string[] documentIds
        boolean isDemo
        datetime createdAt
        datetime updatedAt
    }

    Document {
        string id PK
        string workspaceId FK
        string fileName
        string fileType
        int fileSize
        int pageCount
        int wordCount
        string parseStatus
        string[] tags
        boolean isFavorite
        int chunkCount
    }

    DocumentChunk {
        string id PK
        string documentId FK
        string content
        int pageNumber
        string sectionTitle
        int position
        string[] keywords
    }

    Citation {
        string id PK
        string chunkId FK
        string documentId FK
        string documentName
        string text
        int pageNumber
        string relation
        float relevanceScore
    }

    Claim {
        string id PK
        string content
        string confidence
        int evidenceCount
        int supportCount
        int contradictCount
    }

    Evidence {
        string id PK
        string claimId FK
        string citationId FK
        string documentId FK
        string relation
    }

    DecisionBrief {
        string id PK
        string projectId FK
        string title
        string target
        string audience
        string detail
    }
